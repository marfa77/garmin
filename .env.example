# Garmin OAuth — https://developer.garmin.com/ (Connect Developer Program)
# Redirect URI: {NEXT_PUBLIC_APP_URL}/api/garmin/oauth/callback
GARMIN_CLIENT_ID=
GARMIN_CLIENT_SECRET=

# Garmin (local Python sync only — not used in browser connect)
GARMIN_EMAIL=your@email.com
GARMIN_PASSWORD=your-password
# GARMINTOKENS=data/.garmin-tokens

# OpenRouter — AI coach
OPENROUTER_API_KEY=
OPENROUTER_COACH_MODEL=google/gemini-2.5-flash

# Supabase — https://supabase.com/dashboard/project/wcwadwcjqutdxwbrkyai
NEXT_PUBLIC_SUPABASE_URL=https://wcwadwcjqutdxwbrkyai.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Access — set true to skip Gumroad paywall (beta / demand testing)
FREE_BETA=true
NEXT_PUBLIC_FREE_BETA=true

# Owner account — skips Garmin OAuth gate (comma-separated emails)
OWNER_EMAILS=pv.inform@gmail.com

# Waitlist alerts (same bot as PixID / CIPLE)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Gumroad (optional when FREE_BETA=true; webhook can live on pixid.studio router)
NEXT_PUBLIC_GUMROAD_CHECKOUT_URL=https://pixidstudio.gumroad.com/l/uinvw
GUMROAD_PRODUCT_PERMALINK=uinvw
GUMROAD_WEBHOOK_SECRET=

# App URLs (Vercel)
NEXT_PUBLIC_APP_URL=https://garmin-woad.vercel.app
